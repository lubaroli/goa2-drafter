# Supabase configuration (optional).
#
# Leave both values empty to run the app in single-device mode, where game
# state is persisted to localStorage and the full setup → draft → board flow
# works in one browser (great for offline / pass-the-device play).
#
# Set both values to a real Supabase project to enable async multi-device
# play. Apply `supabase/schema.sql` in the Supabase SQL editor before first
# use. The app picks the backend at runtime: when both vars are non-empty,
# `getGameStore()` returns `SupabaseGameStore`; otherwise `LocalGameStore`.
#
# The anon public key is safe to ship in a static bundle — security relies
# on RLS + unguessable per-player tokens, not on hiding the key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
